// ==========================================================
// Jenkinsfile — EKS Infrastructure Deployment Pipeline
// Domain: Cloud / DevOps (Production Grade)
//
// Prerequisites on the Jenkins agent:
//   - terraform >= 1.9
//   - aws cli >= 2.x
//   - kubectl >= 1.29
//   - Jenkins credential: 'aws-creds' (AWS Credentials Binding)
//
// Run order for a first-time deployment:
//   1. TF_ACTION=plan  , ENVIRONMENT=prod  → verify plan looks correct
//   2. TF_ACTION=apply , ENVIRONMENT=prod  → deploy EKS
// ==========================================================

pipeline {
    agent any

    parameters {
        choice(
            name: 'TF_ACTION',
            choices: ['plan', 'apply', 'destroy'],
            description: 'Terraform action to perform'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment'
        )
    }

    environment {
        AWS_REGION       = 'ap-south-1'
        TF_IN_AUTOMATION = 'true'
        // -no-color avoids ANSI escape codes in Jenkins logs
        TF_CLI_ARGS      = '-no-color'
        TF_BACKEND_BUCKET = 'cloudcart-terraform-state'
        TF_BACKEND_TABLE  = 'terraform-lock'
        // Computed after params are validated
        TF_DIR           = "environments/${params.ENVIRONMENT}"
        TF_PLAN_FILE     = "tfplan-${params.ENVIRONMENT}-${BUILD_NUMBER}"
    }

    options {
        timestamps()
        skipDefaultCheckout(true)
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 90, unit: 'MINUTES')
    }

    stages {

        // ==================================================
        // 1. Validate that the pipeline was triggered with
        //    real parameter values (guards against the first-
        //    run Jenkins "parameter registration" build where
        //    params are null and terraform runs on an empty dir)
        // ==================================================
        stage('Validate Parameters') {
            steps {
                script {
                    if (!params.ENVIRONMENT || !params.TF_ACTION) {
                        error("""
Parameters not set. This happens on the very first build
when Jenkins registers the pipeline parameters.

Re-run the pipeline using 'Build with Parameters' and
select:
  ENVIRONMENT = prod  (or dev / staging)
  TF_ACTION   = plan  (always start with plan)
""")
                    }

                    def validEnvs = ['dev', 'staging', 'prod']
                    def validActions = ['plan', 'apply', 'destroy']

                    if (!validEnvs.contains(params.ENVIRONMENT)) {
                        error("Invalid ENVIRONMENT '${params.ENVIRONMENT}'. Must be one of: ${validEnvs}")
                    }
                    if (!validActions.contains(params.TF_ACTION)) {
                        error("Invalid TF_ACTION '${params.TF_ACTION}'. Must be one of: ${validActions}")
                    }

                    echo """
========================================
 Pipeline Parameters
========================================
 Environment : ${params.ENVIRONMENT}
 Action      : ${params.TF_ACTION}
 Region      : ${env.AWS_REGION}
 TF Dir      : ${env.TF_DIR}
 Plan File   : ${env.TF_PLAN_FILE}
========================================
"""
                }
            }
        }

        // ==================================================
        // 2. Verify required tools are installed on the agent
        // ==================================================
        stage('Verify Tools') {
            steps {
                sh '''
                    set -e
                    echo "=== Verifying required tools ==="
                    terraform version
                    aws --version
                    kubectl version --client
                    echo "=== All tools present ==="
                '''
            }
        }

        // ==================================================
        // 3. Checkout source code
        // ==================================================
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ==================================================
        // 4. Confirm AWS identity and connectivity
        // ==================================================
        stage('AWS Identity') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                        set -e
                        echo "=== AWS Identity ==="
                        aws sts get-caller-identity
                        echo "Region      : ${AWS_REGION}"
                        echo "Environment : ${ENVIRONMENT}"
                        echo "Action      : ${TF_ACTION}"
                    '''
                }
            }
        }

        // ==================================================
        // 5. Bootstrap Terraform Backend (idempotent)
        //
        //    Creates the S3 bucket and DynamoDB table that
        //    Terraform uses for remote state + locking.
        //    This MUST run before terraform init.
        //    Safe to re-run — skips resources that already exist.
        // ==================================================
        stage('Bootstrap Backend') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                        set -e
                        echo "=== Bootstrapping Terraform Backend ==="
                        BUCKET="${TF_BACKEND_BUCKET}"
                        TABLE="${TF_BACKEND_TABLE}"
                        REGION="${AWS_REGION}"

                        # ── S3 Bucket ─────────────────────────────────────
                        if aws s3api head-bucket --bucket "$BUCKET" --region "$REGION" 2>/dev/null; then
                            echo "S3 bucket already exists: $BUCKET"
                        else
                            echo "Creating S3 bucket: $BUCKET"
                            aws s3api create-bucket \
                                --bucket "$BUCKET" \
                                --region "$REGION" \
                                --create-bucket-configuration LocationConstraint="$REGION"

                            # Versioning — allows state file recovery
                            aws s3api put-bucket-versioning \
                                --bucket "$BUCKET" \
                                --versioning-configuration Status=Enabled

                            # Server-side encryption (AES256)
                            aws s3api put-bucket-encryption \
                                --bucket "$BUCKET" \
                                --server-side-encryption-configuration \
                                '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'

                            # Block all public access
                            aws s3api put-public-access-block \
                                --bucket "$BUCKET" \
                                --public-access-block-configuration \
                                "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true"

                            echo "S3 bucket created and secured."
                        fi

                        # ── DynamoDB Table ────────────────────────────────
                        if aws dynamodb describe-table \
                                --table-name "$TABLE" \
                                --region "$REGION" \
                                --query 'Table.TableStatus' \
                                --output text 2>/dev/null | grep -q ACTIVE; then
                            echo "DynamoDB table already exists: $TABLE"
                        else
                            echo "Creating DynamoDB table: $TABLE"
                            aws dynamodb create-table \
                                --table-name "$TABLE" \
                                --attribute-definitions AttributeName=LockID,AttributeType=S \
                                --key-schema AttributeName=LockID,KeyType=HASH \
                                --billing-mode PAY_PER_REQUEST \
                                --region "$REGION"

                            echo "Waiting for table to become ACTIVE..."
                            aws dynamodb wait table-exists \
                                --table-name "$TABLE" \
                                --region "$REGION"
                            echo "DynamoDB table is ACTIVE."
                        fi

                        echo "=== Backend is ready ==="
                    '''
                }
            }
        }

        // ==================================================
        // 6. Check Terraform formatting (read-only, never modifies)
        // ==================================================
        stage('Terraform Format') {
            steps {
                sh 'terraform fmt -check -recursive'
            }
        }

        // ==================================================
        // 7. Initialize Terraform (downloads providers,
        //    connects to S3 backend)
        // ==================================================
        stage('Terraform Init') {
            steps {
                timeout(time: 15, unit: 'MINUTES') {
                    dir(env.TF_DIR) {
                        withCredentials([[
                            $class: 'AmazonWebServicesCredentialsBinding',
                            credentialsId: 'aws-creds'
                        ]]) {
                            sh '''
                                set -e
                                echo "=== Terraform Init: ${TF_DIR} ==="
                                terraform init -input=false
                                echo "=== Init complete ==="
                            '''
                        }
                    }
                }
            }
        }

        // ==================================================
        // 8. Validate Terraform configuration
        // ==================================================
        stage('Terraform Validate') {
            steps {
                dir(env.TF_DIR) {
                    sh '''
                        set -e
                        echo "=== Terraform Validate ==="
                        terraform validate
                        echo "=== Validate passed ==="
                    '''
                }
            }
        }

        // ==================================================
        // 9. Generate Terraform plan
        //    For destroy action, -destroy flag is added.
        //    Plan file is saved and reused in the Apply step.
        // ==================================================
        stage('Terraform Plan') {
            steps {
                timeout(time: 20, unit: 'MINUTES') {
                    dir(env.TF_DIR) {
                        withCredentials([[
                            $class: 'AmazonWebServicesCredentialsBinding',
                            credentialsId: 'aws-creds'
                        ]]) {
                            sh """
                                set -e
                                echo "=== Terraform Plan ==="
                                terraform plan \\
                                  -input=false \\
                                  -out=${env.TF_PLAN_FILE} \\
                                  ${params.TF_ACTION == 'destroy' ? '-destroy' : ''}
                                echo "=== Plan saved: ${env.TF_PLAN_FILE} ==="
                            """
                        }
                    }
                }
            }
        }

        // ==================================================
        // 10. Manual approval gate
        //     Only runs for apply and destroy.
        //     Destroy shows a stronger warning message.
        //     Times out automatically after 30 min.
        // ==================================================
        stage('Approval') {
            when {
                anyOf {
                    expression { params.TF_ACTION == 'apply'   }
                    expression { params.TF_ACTION == 'destroy' }
                }
            }
            options {
                timeout(time: 30, unit: 'MINUTES')
            }
            steps {
                script {
                    def envUpper = params.ENVIRONMENT.toUpperCase()
                    def msg = (params.TF_ACTION == 'destroy')
                        ? "CRITICAL: You are about to DESTROY the ${envUpper} environment. This is IRREVERSIBLE. Proceed?"
                        : "Approve terraform apply for [${envUpper}] environment?"
                    input message: msg, ok: 'Proceed'
                }
            }
        }

        // ==================================================
        // 11. Apply or Destroy using the saved plan file
        //     The plan file ensures exactly what was reviewed
        //     in the Plan stage gets applied — no drift.
        // ==================================================
        stage('Terraform Execute') {
            when {
                anyOf {
                    expression { params.TF_ACTION == 'apply'   }
                    expression { params.TF_ACTION == 'destroy' }
                }
            }
            steps {
                timeout(time: 60, unit: 'MINUTES') {
                    dir(env.TF_DIR) {
                        withCredentials([[
                            $class: 'AmazonWebServicesCredentialsBinding',
                            credentialsId: 'aws-creds'
                        ]]) {
                            sh """
                                set -e
                                echo "=== Terraform Execute: ${params.TF_ACTION} ==="
                                terraform apply -input=false -auto-approve ${env.TF_PLAN_FILE}
                                echo "=== Execute complete ==="
                            """
                        }
                    }
                }
            }
        }

        // ==================================================
        // 12. Configure kubeconfig on the Jenkins agent.
        //     - Reads cluster name from terraform output
        //       (single source of truth, no hardcoding)
        //     - Waits until EKS control plane is ACTIVE
        //     - Updates ~/.kube/config on the Jenkins agent
        // ==================================================
        stage('Configure kubeconfig') {
            when {
                expression { params.TF_ACTION == 'apply' }
            }
            steps {
                timeout(time: 20, unit: 'MINUTES') {
                    dir(env.TF_DIR) {
                        withCredentials([[
                            $class: 'AmazonWebServicesCredentialsBinding',
                            credentialsId: 'aws-creds'
                        ]]) {
                            script {
                                def clusterName = sh(
                                    script: 'terraform output -raw cluster_name',
                                    returnStdout: true
                                ).trim()

                                sh """
                                    set -e
                                    echo "=== Configuring kubeconfig for: ${clusterName} ==="
                                    aws eks wait cluster-active \\
                                        --region ${env.AWS_REGION} \\
                                        --name   ${clusterName}
                                    aws eks update-kubeconfig \\
                                        --region ${env.AWS_REGION} \\
                                        --name   ${clusterName}
                                    echo "=== kubeconfig configured ==="
                                """
                            }
                        }
                    }
                }
            }
        }

        // ==================================================
        // 13. Verify the cluster is healthy
        //     Waits up to 10 min for all nodes to be Ready,
        //     then prints node + system pod status.
        // ==================================================
        stage('Verify Cluster') {
            when {
                expression { params.TF_ACTION == 'apply' }
            }
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    sh '''
                        set -e
                        echo "=== Waiting for all nodes to be Ready... ==="
                        kubectl wait --for=condition=Ready nodes \\
                          --all \\
                          --timeout=600s

                        echo ""
                        echo "=== Node Status ==="
                        kubectl get nodes -o wide

                        echo ""
                        echo "=== System Pods (kube-system) ==="
                        kubectl get pods -n kube-system

                        echo ""
                        echo "=== Cluster is healthy and ready ==="
                    '''
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "SUCCESS | action=${params.TF_ACTION} | env=${params.ENVIRONMENT} | build=#${BUILD_NUMBER}"
        }
        failure {
            echo "FAILED  | action=${params.TF_ACTION} | env=${params.ENVIRONMENT} | build=#${BUILD_NUMBER}"
        }
        aborted {
            echo "ABORTED | build=#${BUILD_NUMBER}"
        }
    }
}
