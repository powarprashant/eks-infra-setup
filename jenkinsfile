agent any

```
environment {
    AWS_REGION = "ap-south-1"
}

stages {

    stage('Checkout Code') {
        steps {
            cleanWs()
            checkout scm
        }
    }

    stage('Terraform Format Check') {
        steps {
            withVault([
                configuration: [
                    vaultUrl: 'http://<VAULT_SERVER_IP>:8200',
                    vaultCredentialId: 'jenkins-vault-access',
                    engineVersion: 2
                ],
                vaultSecrets: [
                    [
                        path: 'secret/aws',
                        secretValues: [
                            [envVar: 'AWS_ACCESS_KEY_ID', vaultKey: 'access_key'],
                            [envVar: 'AWS_SECRET_ACCESS_KEY', vaultKey: 'secret-access_key']
                        ]
                    ],
                    [
                        path: 'secret/db',
                        secretValues: [
                            [envVar: 'TF_VAR_db_username', vaultKey: 'db_username'],
                            [envVar: 'TF_VAR_db_password', vaultKey: 'db_password']
                        ]
                    ],
                    [
                        path: 'secret/docker',
                        secretValues: [
                            [envVar: 'DOCKER_USERNAME', vaultKey: 'docker_username'],
                            [envVar: 'DOCKER_PASSWORD', vaultKey: 'docker_password']
                        ]
                    ]
                ]
            ]) {
                dir('environments/dev') {
                    sh 'terraform fmt -check'
                }
            }
        }
    }

    stage('Terraform Init') {
        steps {
            withVault([
                configuration: [
                    vaultUrl: 'http://<VAULT_SERVER_IP>:8200',
                    vaultCredentialId: 'jenkins-vault-access',
                    engineVersion: 2
                ],
                vaultSecrets: [
                    [
                        path: 'secret/aws',
                        secretValues: [
                            [envVar: 'AWS_ACCESS_KEY_ID', vaultKey: 'access_key'],
                            [envVar: 'AWS_SECRET_ACCESS_KEY', vaultKey: 'secret-access_key']
                        ]
                    ],
                    [
                        path: 'secret/db',
                        secretValues: [
                            [envVar: 'TF_VAR_db_username', vaultKey: 'db_username'],
                            [envVar: 'TF_VAR_db_password', vaultKey: 'db_password']
                        ]
                    ],
                    [
                        path: 'secret/docker',
                        secretValues: [
                            [envVar: 'DOCKER_USERNAME', vaultKey: 'docker_username'],
                            [envVar: 'DOCKER_PASSWORD', vaultKey: 'docker_password']
                        ]
                    ]
                ]
            ]) {
                dir('environments/dev') {
                    sh 'terraform init'
                }
            }
        }
    }

    stage('Terraform Validate') {
        steps {
            dir('environments/dev') {
                sh 'terraform validate'
            }
        }
    }

