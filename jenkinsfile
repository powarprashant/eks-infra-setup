// ==========================================================
// Jenkinsfile — EKS Infrastructure Deployment Pipeline
// Domain: Cloud / DevOps (Production Grade)
// ==========================================================

pipeline {
    agent any

    parameters {
        choice(
            name: 'TF_ACTION',
            choices: ['plan', 'apply', 'destroy'],
            description: 'Terraform action to perform'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'staging', 'prod'],
            description: 'Target environment'
        )
    }

    environment {
        AWS_REGION       = 'ap-south-1'
        TF_IN_AUTOMATION = 'true'
        TF_DIR           = "environments/${params.ENVIRONMENT}"
        TF_PLAN_FILE     = "tfplan-${params.ENVIRONMENT}-${BUILD_NUMBER}"
    }

    options {
        timestamps()
        skipDefaultCheckout(true)
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 90, unit: 'MINUTES')
    }

    stages {

        // ==================================================
        // Tool Verification
        // ==================================================
        stage('Verify Tools') {
            steps {
                sh '''
                    set -e
                    echo "=== Verifying required tools ==="
                    terraform version
                    aws --version
                    kubectl version --client
                '''
            }
        }

        // ==================================================
        // Checkout Code
        // ==================================================
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ==================================================
        // AWS Identity Validation
        // ==================================================
        stage('AWS Identity') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-creds'
                ]]) {
                    sh '''
                        set -e
                        echo "=== AWS Identity ==="
                        aws sts get-caller-identity
                        echo "Region      : ${AWS_REGION}"
                        echo "Environment : ${ENVIRONMENT}"
                        echo "Action      : ${TF_ACTION}"
                    '''
                }
            }
        }

        // ==================================================
        // Terraform Format Check
        // ==================================================
        stage('Terraform Format') {
            steps {
                sh 'terraform fmt -check -recursive'
            }
        }

        // ==================================================
        // Terraform Init
        // ==================================================
        stage('Terraform Init') {
            steps {
                dir(env.TF_DIR) {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh '''
                            set -e
                            terraform init -input=false
                        '''
                    }
                }
            }
        }

        // ==================================================
        // Terraform Validate
        // ==================================================
        stage('Terraform Validate') {
            steps {
                dir(env.TF_DIR) {
                    sh 'terraform validate'
                }
            }
        }

        // ==================================================
        // Terraform Plan
        // ==================================================
        stage('Terraform Plan') {
            steps {
                dir(env.TF_DIR) {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh """
                            set -e
                            terraform plan \
                              -input=false \
                              -out=${env.TF_PLAN_FILE} \
                              ${params.TF_ACTION == 'destroy' ? '-destroy' : ''}
                        """
                    }
                }
            }
        }

        // ==================================================
        // Manual Approval (Critical Step)
        // ==================================================
        stage('Approval') {
            when {
                anyOf {
                    expression { params.TF_ACTION == 'apply' }
                    expression { params.TF_ACTION == 'destroy' }
                }
            }
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    script {
                        def msg = params.TF_ACTION == 'destroy' ?
                            "CRITICAL: Destroy ${params.ENVIRONMENT.toUpperCase()} environment?" :
                            "Approve APPLY for ${params.ENVIRONMENT.toUpperCase()}?"

                        input message: msg, ok: 'Proceed'
                    }
                }
            }
        }

        // ==================================================
        // Terraform Apply / Destroy
        // ==================================================
        stage('Terraform Execute') {
            when {
                anyOf {
                    expression { params.TF_ACTION == 'apply' }
                    expression { params.TF_ACTION == 'destroy' }
                }
            }
            steps {
                dir(env.TF_DIR) {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        sh """
                            set -e
                            terraform apply -input=false -auto-approve ${env.TF_PLAN_FILE}
                        """
                    }
                }
            }
        }

        // ==================================================
        // Configure kubeconfig
        // ==================================================
        stage('Configure kubeconfig') {
            when {
                expression { params.TF_ACTION == 'apply' }
            }
            steps {
                dir(env.TF_DIR) {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds'
                    ]]) {
                        script {
                            def clusterName = sh(
                                script: 'terraform output -raw cluster_name',
                                returnStdout: true
                            ).trim()

                            sh """
                                set -e
                                aws eks wait cluster-active --region ${env.AWS_REGION} --name ${clusterName}
                                aws eks update-kubeconfig --region ${env.AWS_REGION} --name ${clusterName}
                            """

                            echo "Configured kubeconfig for cluster: ${clusterName}"
                        }
                    }
                }
            }
        }

        // ==================================================
        // Verify Cluster Health
        // ==================================================
        stage('Verify Cluster') {
            when {
                expression { params.TF_ACTION == 'apply' }
            }
            steps {
                sh '''
                    set -e
                    echo "=== Waiting for nodes ==="
                    kubectl wait --for=condition=Ready nodes --all --timeout=600s

                    echo "=== Nodes ==="
                    kubectl get nodes -o wide

                    echo "=== System Pods ==="
                    kubectl get pods -n kube-system
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "SUCCESS: ${params.TF_ACTION} on ${params.ENVIRONMENT}"
        }
        failure {
            echo "FAILED: ${params.TF_ACTION} on ${params.ENVIRONMENT}"
        }
        aborted {
            echo "ABORTED by user"
        }
    }
}